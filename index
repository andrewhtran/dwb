<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DWB Beauty — Strategic Growth Portal</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy:#0f1729;
    --navy-soft:#182238;
    --navy-line:rgba(255,255,255,0.08);
    --accent:#3b5bdb;
    --accent-soft:rgba(59,91,219,0.10);
    --ink:#181b29;
    --ink-soft:#5c6178;
    --ink-faint:#8890a4;
    --bg:#f6f5f1;
    --card:#ffffff;
    --border:#e6e3dc;
    --green:#1a7f4e; --green-bg:#e5f4ec;
    --yellow:#9c6a12; --yellow-bg:#fbf1dc;
    --red:#b13b3b; --red-bg:#fbe8e7;
    --gray:#4b5165; --gray-bg:#eef0f5;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    font-family:'Inter',-apple-system,sans-serif;
    background:var(--bg);
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
  }
  .app{display:flex;min-height:100vh;}

  /* ---------- SIDEBAR ---------- */
  .sidebar{
    width:278px;flex-shrink:0;background:var(--navy);
    display:flex;flex-direction:column;
    position:fixed;top:0;left:0;bottom:0;overflow-y:auto;
  }
  .sidebar-header{padding:2rem 1.6rem 1.4rem;border-bottom:1px solid var(--navy-line);}
  .sidebar-header .brand{
    font-family:'Fraunces',serif;font-weight:600;font-size:1.55rem;color:#fff;
    letter-spacing:.01em;line-height:1.15;
  }
  .sidebar-header .brand-sub{
    display:block;margin-top:.55rem;font-size:.66rem;font-weight:600;
    letter-spacing:.16em;text-transform:uppercase;color:#7d87a3;
  }
  .nav-scroll{flex:1;padding:1.3rem 0 1rem;}
  .nav-group{margin-bottom:1.5rem;}
  .nav-group-label{
    font-size:.64rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
    color:#5f6883;padding:0 1.6rem;margin-bottom:.5rem;
  }
  .nav-item{
    display:flex;align-items:center;gap:.55rem;
    padding:.56rem 1.6rem;font-size:.855rem;font-weight:500;color:#aab1c6;
    cursor:pointer;border-left:3px solid transparent;transition:background .12s,color .12s;
    user-select:none;
  }
  .nav-item:hover{color:#fff;background:rgba(255,255,255,.045);}
  .nav-item.active{color:#fff;background:var(--accent);border-left-color:#fff;}
  .nav-dot{width:5px;height:5px;border-radius:50%;background:currentColor;opacity:.55;flex-shrink:0;}
  .sidebar-footer{
    padding:1.1rem 1.6rem 1.4rem;border-top:1px solid var(--navy-line);
    font-size:.7rem;color:#5f6883;line-height:1.5;
  }

  /* ---------- MAIN ---------- */
  .content{margin-left:278px;flex:1;padding:2.8rem 3.4rem 5rem;max-width:1180px;}
  .page{display:none;}
  .page.active{display:block;animation:fadeIn .25s ease;}
  @keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:none;}}

  .page-top{display:flex;align-items:flex-start;justify-content:space-between;gap:2rem;margin-bottom:.4rem;}
  .eyebrow{
    font-size:.72rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;
    color:var(--accent);margin-bottom:.6rem;display:block;
  }
  h1.page-title{
    font-family:'Fraunces',serif;font-weight:600;font-size:2.15rem;line-height:1.12;
    margin:0 0 .65rem;color:var(--ink);letter-spacing:-.01em;
  }
  .page-subhead{color:var(--ink-soft);font-size:.95rem;line-height:1.55;max-width:640px;margin:0 0 2rem;}
  .context-pill{
    flex-shrink:0;border:1px solid var(--border);background:#fff;border-radius:999px;
    padding:.4rem 1rem;font-size:.72rem;color:var(--ink-soft);white-space:nowrap;margin-top:.2rem;
    font-weight:500;
  }

  /* ---------- CARD ---------- */
  .card{
    background:var(--card);border:1px solid var(--border);border-radius:14px;
    box-shadow:0 1px 3px rgba(15,23,41,.04);padding:1.7rem 1.8rem;margin-bottom:1.6rem;
  }
  .card-head{display:flex;align-items:center;gap:.65rem;margin-bottom:1.3rem;}
  .card-head .bar{width:4px;height:1.05rem;background:var(--accent);border-radius:2px;flex-shrink:0;}
  .card-head .label{font-weight:700;font-size:.98rem;color:var(--ink);}
  .card-note{font-size:.8rem;color:var(--ink-faint);margin:-.6rem 0 1.1rem;line-height:1.5;}

  /* ---------- TABLE ---------- */
  .tbl-wrap{overflow-x:auto;}
  table{width:100%;border-collapse:collapse;font-size:.85rem;}
  th{
    text-align:left;font-size:.66rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
    color:var(--ink-faint);padding:.55rem .6rem;border-bottom:1px solid var(--border);white-space:nowrap;
  }
  td{padding:.85rem .6rem;border-bottom:1px solid var(--border);vertical-align:top;line-height:1.5;color:var(--ink);}
  tr:last-child td{border-bottom:none;}
  td.dim{font-weight:600;white-space:nowrap;}
  td.assess{color:var(--ink-soft);max-width:420px;}

  /* ---------- PILLS ---------- */
  .pill{
    display:inline-flex;align-items:center;gap:.3rem;padding:.24rem .62rem;border-radius:999px;
    font-size:.7rem;font-weight:700;white-space:nowrap;
  }
  .pill-green{background:var(--green-bg);color:var(--green);}
  .pill-yellow{background:var(--yellow-bg);color:var(--yellow);}
  .pill-red{background:var(--red-bg);color:var(--red);}
  .pill-blue{background:var(--accent-soft);color:var(--accent);}
  .pill-gray{background:var(--gray-bg);color:var(--gray);}

  .conf-dots{display:inline-flex;gap:3px;margin-left:.45rem;vertical-align:middle;}
  .conf-dots .d{width:5px;height:5px;border-radius:50%;background:var(--border);}
  .conf-dots .d.on{background:var(--accent);}

  /* ---------- ROADMAP ---------- */
  .roadmap-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;}
  @media(max-width:980px){.roadmap-grid{grid-template-columns:1fr;}}
  .phase-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.5rem 1.5rem 1.6rem;box-shadow:0 1px 3px rgba(15,23,41,.04);}
  .phase-card h3{font-family:'Fraunces',serif;font-size:1.15rem;margin:0 0 .2rem;color:var(--ink);}
  .phase-card .phase-range{font-size:.7rem;color:var(--ink-faint);letter-spacing:.05em;text-transform:uppercase;font-weight:600;margin-bottom:1.1rem;display:block;}
  .work-item{border-top:1px solid var(--border);padding:.85rem 0;}
  .work-item:first-of-type{border-top:none;}
  .work-item .pillar-tag{font-size:.62rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--accent);}
  .work-item .ws-title{font-weight:600;font-size:.87rem;margin:.25rem 0 .3rem;color:var(--ink);}
  .work-item .ws-meta{font-size:.76rem;color:var(--ink-soft);line-height:1.5;}
  .work-item .ws-meta b{color:var(--ink);font-weight:600;}

  /* ---------- KPI ---------- */
  .kpi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;}
  @media(max-width:980px){.kpi-grid{grid-template-columns:repeat(2,1fr);}}
  @media(max-width:640px){.kpi-grid{grid-template-columns:1fr;}}
  .kpi-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.4rem 1.5rem;box-shadow:0 1px 3px rgba(15,23,41,.04);}
  .kpi-card .kpi-label{font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-faint);margin-bottom:.6rem;}
  .kpi-card .kpi-value{font-family:'Fraunces',serif;font-size:1.85rem;font-weight:600;color:var(--ink);line-height:1;}
  .kpi-card .kpi-target{font-size:.78rem;color:var(--accent);font-weight:600;margin-top:.5rem;}
  .kpi-card .kpi-note{font-size:.76rem;color:var(--ink-soft);margin-top:.35rem;line-height:1.5;}

  /* ---------- LIST CARDS (opportunities/risks) ---------- */
  .item-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:1.3rem 1.5rem;margin-bottom:1rem;box-shadow:0 1px 3px rgba(15,23,41,.04);}
  .item-card .item-head{display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:.55rem;}
  .item-card .item-title{font-weight:700;font-size:.92rem;color:var(--ink);}
  .item-card .item-body{font-size:.85rem;color:var(--ink-soft);line-height:1.6;}
  .item-card .item-body b{color:var(--ink);font-weight:600;}

  .rec-list{margin:0;padding:0;list-style:none;}
  .rec-list li{
    padding:1rem 0 1rem 1.9rem;border-top:1px solid var(--border);position:relative;
    font-size:.9rem;color:var(--ink-soft);line-height:1.6;
  }
  .rec-list li:first-child{border-top:none;}
  .rec-list li::before{
    content:'';position:absolute;left:0;top:1.35rem;width:8px;height:8px;border-radius:50%;background:var(--accent);
  }
  .rec-list li b{color:var(--ink);}

  .footnote{font-size:.76rem;color:var(--ink-faint);margin-top:1.6rem;line-height:1.6;}

  ::-webkit-scrollbar{width:8px;height:8px;}
  ::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:8px;}
  .sidebar::-webkit-scrollbar-thumb{background:rgba(255,255,255,.12);}

  @media(max-width:860px){
    .sidebar{position:relative;width:100%;height:auto;}
    .content{margin-left:0;padding:2rem 1.4rem 4rem;}
    .app{flex-direction:column;}
  }
</style>
</head>
<body>
<div class="app">

  <!-- ============ SIDEBAR ============ -->
  <aside class="sidebar">
    <div class="sidebar-header">
      <span class="brand">DWB Beauty</span>
      <span class="brand-sub">Strategic Growth Portal</span>
    </div>

    <nav class="nav-scroll">
      <div class="nav-group">
        <div class="nav-group-label">Executive Overview</div>
        <div class="nav-item active" data-page="exec-summary"><span class="nav-dot"></span>Executive Summary</div>
        <div class="nav-item" data-page="roadmap"><span class="nav-dot"></span>90-Day Roadmap</div>
        <div class="nav-item" data-page="kpi"><span class="nav-dot"></span>KPI Dashboard</div>
      </div>

      <div class="nav-group">
        <div class="nav-group-label">Diagnostic</div>
        <div class="nav-item" data-page="current-state"><span class="nav-dot"></span>Current State Assessment</div>
        <div class="nav-item" data-page="benchmark"><span class="nav-dot"></span>Competitor Benchmark</div>
      </div>

      <div class="nav-group">
        <div class="nav-group-label">Growth Strategy</div>
        <div class="nav-item" data-page="op-foundation"><span class="nav-dot"></span>Operational Foundation</div>
        <div class="nav-item" data-page="website-seo"><span class="nav-dot"></span>Website, SEO &amp; Ecommerce</div>
        <div class="nav-item" data-page="paid-retention"><span class="nav-dot"></span>Paid Ads &amp; Retention Systems</div>
        <div class="nav-item" data-page="content-social"><span class="nav-dot"></span>Content &amp; Social</div>
      </div>

      <div class="nav-group">
        <div class="nav-group-label">Opportunities &amp; Risks</div>
        <div class="nav-item" data-page="opportunities"><span class="nav-dot"></span>Key Opportunities</div>
        <div class="nav-item" data-page="risks"><span class="nav-dot"></span>Key Risks</div>
        <div class="nav-item" data-page="final-recs"><span class="nav-dot"></span>Final Recommendations</div>
      </div>
    </nav>

    <div class="sidebar-footer">Prepared by eComm Cartel · July 2026</div>
  </aside>

  <!-- ============ MAIN CONTENT ============ -->
  <main class="content">

    <!-- ============ EXECUTIVE SUMMARY ============ -->
    <section class="page active" id="exec-summary">
      <div class="page-top">
        <div>
          <span class="eyebrow">01 · Executive Overview</span>
          <h1 class="page-title">Executive Summary</h1>
          <p class="page-subhead">A one-page synthesis of research, diagnostic, strategy, and roadmap — built for Dr. Whitney Bowe and the incoming leadership team ahead of the SAFE round close.</p>
        </div>
        <span class="context-pill">New York, NY · DTC-First</span>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Overall Business Health</span></div>
        <p style="color:var(--ink-soft);font-size:.92rem;line-height:1.7;margin:0;">
          DWB Beauty is a fast-growing, well-differentiated clinical skincare brand — $4.9M revenue in 2025 (+70% YoY), targeting ~$7.5M in 2026 (+50–60%), with improving unit economics (Q1 2026 gross margin 87%, up from 84%; LTV/CAC 3.7x). The brand's core asset — Dr. Bowe's clinical credibility, 25 completed studies, and 3 peer-reviewed publications — is genuinely strong and stands out even against a competitive set of well-funded dermatologist and physician-dispensed brands. The gap is operational, not brand-level: the infrastructure behind the brand (website/ecommerce ownership, paid marketing access, project management, marketing tech stack) hasn't kept pace with growth, and this comes to a head right as DWB closes a friends-and-family SAFE round extension targeted for July 31, 2026.
        </p>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Top 3 Strengths</span></div>
        <ul class="rec-list">
          <li><b>Clinical validation &amp; credibility</b> — 25 independent clinical studies, 3 published in peer-reviewed dermatology journals, and Dr. Bowe's own credentials (Yale/UPenn, 22 "Top Doctor" awards) produced the highest trust-signal score in the competitive benchmark, tied with Dr. Dennis Gross and Dr. Idriss.</li>
          <li><b>Financial trajectory</b> — 70% revenue growth in 2025, accelerating unit economics into 2026 (AOV +65% YoY, gross profit +24% YoY), and organically strong retention (38% loyalty rate, 40%+ hero-SKU retention) despite no dedicated retention infrastructure yet in place.</li>
          <li><b>Social/content foundation</b> — 1.3M followers and 7 videos generating 11.2M+ views in six months, backed by 39+ TV appearances in 2025 self-reported to drive a 4–5x sales lift.</li>
        </ul>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Top 3 Weaknesses</span></div>
        <ul class="rec-list">
          <li><b>No dedicated Project Manager</b> — in Andrew's own words: "each connecting arrow is a potential bottleneck." Every other operational gap depends on this one closing first.</li>
          <li><b>No confirmed website/ecommerce ownership</b> — Shopify management, development, and UI/UX all sit unfilled, even as Q1 2026 AOV and conversion rate are already improving and need protecting.</li>
          <li><b>Unresolved paid marketing (Meta) access</b> — directly threatens the fall 2026 revenue initiatives (eye cream launch, ABC Deals &amp; Steals, holiday season).</li>
        </ul>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Biggest Opportunities (ranked)</span></div>
        <ul class="rec-list">
          <li><b>Resolve Meta/paid ad access</b> — highest-scoring opportunity in the prioritization matrix (4.5/5): high impact, high revenue potential, lowest implementation effort of any item identified.</li>
          <li><b>Establish website/ecommerce ownership</b> (4.0/5) — compounds AOV/CVR gains already happening organically.</li>
          <li><b>Hire a dedicated Project Manager</b> (3.75/5) — the highest business-impact score of any opportunity, and the unlock for nearly everything else.</li>
        </ul>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Biggest Risks</span></div>
        <ul class="rec-list">
          <li><b>Regulatory exposure ahead of the SAFE round close</b> — DWB's ~$4.9M revenue clears the MoCRA small-business exemption threshold, and compliance status has never been verified, with roughly two weeks left before the July 31, 2026 close target.</li>
          <li><b>A single hire covering two competing workstreams</b> — the same developer profile is needed for both ecommerce ownership and marketing tech-stack integration.</li>
          <li><b>Hiring under time pressure</b> — Whitney's stated urgency to "move fast" creates real risk of a rushed PM hire that doesn't fit the "lean, scrappy" culture she's asked for.</li>
        </ul>
      </div>

      <div class="card">
        <div class="card-head"><span class="bar"></span><span class="label">Recommended Priorities — First 90 Days</span></div>
        <ul class="rec-list">
          <li><b>Paid marketing unblocked and running</b> ahead of the fall revenue initiatives.</li>
          <li><b>Ecommerce operations fully owned</b>, protecting and compounding AOV/CVR gains already underway.</li>
          <li><b>Cross-functional execution unblocked</b> through dedicated project management.</li>
          <li><b>SEO visibility and a promotional calendar established</b> ahead of the holiday selling season.</li>
          <li><b>Regulatory compliance confirmed</b> before the SAFE round closes.</li>
        </ul>
      </div>
    </section>

    <!-- ============ 90-DAY ROADMAP ============ -->
    <section class="page" id="roadmap">
      <div class="page-top">
        <div>
          <span class="eyebrow">02 · Execution</span>
          <h1 class="page-title">90-Day Roadmap</h1>
          <p class="page-subhead">Sequenced so Quick Wins move first wherever their blockers are already resolved; everything else waits for its dependency to clear.</p>
        </div>
        <span class="context-pill">Target close: Jul 31, 2026</span>
      </div>

      <div class="roadmap-grid">
        <div class="phase-card">
          <h3>Foundation</h3>
          <span class="phase-range">Days 1 – 30</span>

          <div class="work-item">
            <span class="pillar-tag">Revenue Engine</span>
            <div class="ws-title">Resolve Meta/paid ad account access</div>
            <div class="ws-meta"><b>Owner:</b> Cici / Whitney<br><b>Milestone:</b> Access confirmed within 7 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Operational Foundation</span>
            <div class="ws-title">Hire dedicated Project Manager</div>
            <div class="ws-meta"><b>Owner:</b> Whitney / Ilaa (COO)<br><b>Milestone:</b> Role filled within 30 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Revenue Engine</span>
            <div class="ws-title">Complete SEO audit</div>
            <div class="ws-meta"><b>Owner:</b> Andrew (eCC)<br><b>Milestone:</b> Audit complete within 30 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Revenue Engine</span>
            <div class="ws-title">Build fall/holiday promotional calendar</div>
            <div class="ws-meta"><b>Owner:</b> Cici<br><b>Milestone:</b> Calendar (Jul–Dec) complete within 30 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Risk Diversification</span>
            <div class="ws-title">Verify MoCRA compliance status</div>
            <div class="ws-meta"><b>Owner:</b> Whitney / legal counsel<br><b>Milestone:</b> Confirmed before SAFE round closes</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Risk Diversification</span>
            <div class="ws-title">Establish Reddit/community sentiment baseline</div>
            <div class="ws-meta"><b>Owner:</b> Andrew, or PM once hired<br><b>Milestone:</b> Baseline complete within 30 days</div>
          </div>
        </div>

        <div class="phase-card">
          <h3>Build-Out</h3>
          <span class="phase-range">Days 31 – 60</span>

          <div class="work-item">
            <span class="pillar-tag">Operational Foundation</span>
            <div class="ws-title">Search/hire website &amp; ecommerce ownership</div>
            <div class="ws-meta"><b>Owner:</b> Ilaa (COO)<br><b>Dependency:</b> Clears once PM is in place<br><b>Milestone:</b> Role(s) filled within 60–90 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Revenue Engine</span>
            <div class="ws-title">Implement Klaviyo (lifecycle/email)</div>
            <div class="ws-meta"><b>Owner:</b> Ilaa (COO) / Andrew<br><b>Milestone:</b> Platform live within 60 days</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Risk Diversification</span>
            <div class="ws-title">Ongoing Reddit/community monitoring</div>
            <div class="ws-meta"><b>Owner:</b> Andrew / PM<br><b>Milestone:</b> Monthly cadence established</div>
          </div>
        </div>

        <div class="phase-card">
          <h3>Scale</h3>
          <span class="phase-range">Days 61 – 90</span>

          <div class="work-item">
            <span class="pillar-tag">Operational Foundation</span>
            <div class="ws-title">Onboard website/ecommerce hire(s)</div>
            <div class="ws-meta"><b>Owner:</b> Ilaa (COO)<br><b>Milestone:</b> Q3–Q4 AOV maintains/exceeds $98.60; CVR reaches 3.3%+</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Operational Foundation</span>
            <div class="ws-title">Consolidate creative production into 1–2 roles</div>
            <div class="ws-meta"><b>Owner:</b> Cici<br><b>Dependency:</b> Clears once PM is in place<br><b>Milestone:</b> Consolidated to 1–2 roles/vendors</div>
          </div>
          <div class="work-item">
            <span class="pillar-tag">Revenue Engine</span>
            <div class="ws-title">Implement Triple Whale + Atria</div>
            <div class="ws-meta"><b>Owner:</b> Andrew<br><b>Dependency:</b> Clears once ecommerce developer is onboard<br><b>Milestone:</b> Attribution live; loyalty rate trending toward 45%+</div>
          </div>
        </div>
      </div>

      <div class="card" style="margin-top:1.6rem;">
        <div class="card-head"><span class="bar"></span><span class="label">Early Confidence Wins (Days 1–30)</span></div>
        <ul class="rec-list">
          <li><b>Meta access resolved</b> — fastest, most visible fix in the plan; directly unblocks fall revenue initiatives.</li>
          <li><b>SEO audit completed</b> — closes a loop already opened in the original Whitney/Andrew email exchange.</li>
          <li><b>MoCRA verification</b> — de-risks the SAFE round close; shows investors active diligence rather than silence.</li>
        </ul>
      </div>

      <p class="footnote"><b>Deferred past Day 90:</b> Scoping diversification beyond ~97% DTC concentration is intentionally excluded — categorized as a Long-Term Strategic Investment (90+ days), and sequenced after the operational foundation (PM, ecommerce ownership, creative consolidation) so a new channel doesn't stretch an already-understaffed team.</p>
    </section>

    <!-- ============ KPI DASHBOARD ============ -->
    <section class="page" id="kpi">
      <div class="page-top">
        <div>
          <span class="eyebrow">03 · Measurement</span>
          <h1 class="page-title">KPI Dashboard</h1>
          <p class="page-subhead">Baseline and target for every metric tied to a recommendation in this plan.</p>
        </div>
        <span class="context-pill">Baselines as of Q1 2026</span>
      </div>

      <div class="kpi-grid">
        <div class="kpi-card">
